{
  "name": "verinode-backend",
  "version": "1.0.0",
  "description": "Verinode backend API for cryptographic proof verification",
  "main": "src/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ --ext .ts,.js",
    "lint:fix": "eslint src/ --ext .ts,.js --fix",
    "typecheck": "tsc --noEmit",
    "python:install": "pip install -r requirements.txt",
    "python:setup": "python -m spacy download en_core_web_sm"
  },
  "dependencies": {

    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.0",
    "geoip-lite": "^1.4.10",
    "helmet": "^8.0.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.1",
    "pdfkit": "^0.17.2",
    "prom-client": "^15.1.3",
    "winston": "^3.17.0",
    "ipfs-core": "^0.18.0",
    "ipfs-http-client": "^60.0.1",
    "ipfs-pubsub-room": "^4.1.0",
    "cids": "^1.1.9",
    "multihashes": "^4.0.3",
    "it-all": "^3.0.4",
    "it-buffer": "^0.1.6",
    "uint8arrays": "^5.0.1",

  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/express-validator": "^3.0.0",

  },
  "keywords": [
    "stellar",
    "api",
    "blockchain",
    "verification",
    "proofs",
    "web3",
    "ipfs",
    "decentralized-storage"
  ],
  "author": "Verinode Team",
  "license": "MIT",
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.tsx?$": "<rootDir>/jest-ts-transform.cjs"
    },
    "moduleNameMapper": {
      "^ioredis$": "<rootDir>/src/__mocks__/ioredis.js",
      "^express$": "<rootDir>/src/__mocks__/express.js"
    }
  }
}
